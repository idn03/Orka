generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(255)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  assignedTasks Task[] @relation("AssignedTasks")
  createdTasks  Task[] @relation("CreatedTasks")

  @@map("users")
}

model Task {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  dueDate     DateTime?  @map("due_date") @db.Date
  parentId    String?    @map("parent_id") @db.Uuid
  assigneeId  String?    @map("assignee_id") @db.Uuid
  creatorId   String     @map("creator_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  parent    Task?   @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks  Task[]  @relation("Subtasks")
  assignee  User?   @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator   User    @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([status], name: "idx_tasks_status")
  @@index([assigneeId], name: "idx_tasks_assignee_id")
  @@index([parentId], name: "idx_tasks_parent_id")
  @@index([dueDate], name: "idx_tasks_due_date")
  @@map("tasks")
}
