# Orka uses OpenCode CLI for agent orchestration.
#
# Option 1: Direct Anthropic auth
# Configure via: opencode auth login
# Or set: ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: CLIProxyAPI (recommended)
# Run CLIProxyAPI locally, then set:
ANTHROPIC_BASE_URL=http://127.0.0.1:8317
ANTHROPIC_AUTH_TOKEN=sk-dummy
#
# For the target app (app/):
# DATABASE_URL=postgresql://user:password@localhost:5432/orka
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
