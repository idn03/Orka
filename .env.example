# Orka uses OpenCode CLI for agent orchestration.
# Configure your LLM provider via: opencode auth login
#
# Alternatively, set API keys as environment variables:
# ANTHROPIC_API_KEY=sk-ant-...
#
# For the target app (app/):
# DATABASE_URL=postgresql://user:password@localhost:5432/orka
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=http://localhost:3000
